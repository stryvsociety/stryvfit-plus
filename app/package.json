{
  "name": "stryvfit-plus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "cf:preview": "bun --env-file=.env.local run cf:preview:exec",
    "cf:preview:exec": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "bun --env-file=.env.local run cf:deploy:exec",
    "cf:deploy:exec": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:upload": "bun --env-file=.env.local run cf:upload:exec",
    "cf:upload:exec": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "test": "bun test",
    "smoke:support": "node scripts/smoke-support-pipeline.mjs",
    "stripe:setup": "node scripts/setup-stripe-products.mjs",
    "cf:secrets": "node scripts/sync-cloudflare-secrets.mjs",
    "cf:fix-ssl": "node scripts/fix-cloudflare-ssl-dns.mjs",
    "typecheck": "tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/supabase-js": "^2.107.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.18.2",
    "lenis": "^1.3.23",
    "lucide-react": "^0.460.0",
    "next": "15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "postcss": "8.5.15",
    "qs": "6.15.2"
  }
}
